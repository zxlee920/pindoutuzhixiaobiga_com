---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { siteConfig } from '@/config';

const breadcrumbs = [
  { label: '首页', href: '/' },
  { label: '使用条款' },
];
---

<BaseLayout
  title={`使用条款 | ${siteConfig.site.name}`}
  description={`查看拼豆图纸小鼻嘎的使用条款与免责声明`}
>
  <Breadcrumb items={breadcrumbs} />
  <section class="py-6 md:py-10">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-6">拼豆图纸小鼻嘎使用条款</h1>
      <div class="prose prose-gray dark:prose-invert max-w-none">
        <p>欢迎使用拼豆图纸小鼻嘎。访问和使用拼豆图纸小鼻嘎，即表示你已阅读并同意遵守本使用条款。拼豆图纸小鼻嘎致力于为拼豆爱好者提供优质的图纸素材服务，以下是使用拼豆图纸小鼻嘎时需要遵守的条款和规定。</p>
        <h2>拼豆图纸小鼻嘎的服务说明</h2>
        <p>
          拼豆图纸小鼻嘎提供拼豆图纸的浏览、检索、详情查看与下载参考服务。拼豆图纸小鼻嘎精心整理了各类高颜值拼豆图纸素材，包括三角洲、小狗、十二星座、甜品等多种主题。我们会持续优化页面体验，内容结构和功能细节可能随版本调整。拼豆图纸小鼻嘎保留随时修改、暂停或终止部分或全部服务的权利，无需事先通知用户。
        </p>
        <h2>用户使用规范</h2>
        <p>
          用户在使用拼豆图纸小鼻嘎时应遵守适用法律法规和本条款规定。用户不得利用拼豆图纸小鼻嘎从事任何违法或不当行为，包括但不限于：传播违法信息、侵犯他人知识产权、恶意攻击网站、干扰服务正常运行等。由用户使用行为引发的法律风险与责任由用户自行承担，拼豆图纸小鼻嘎不承担任何连带责任。
        </p>
        <h2>知识产权与使用边界</h2>
        <p>
          拼豆图纸小鼻嘎站内的图纸素材主要用于学习、交流与制作参考。拼豆图纸小鼻嘎尊重知识产权，站内图纸可能来源于网络公开资源或用户投稿。除非页面明确授权，未经权利人许可，用户不得将相关图纸用于商业分发、二次售卖、侵权用途或其他侵犯知识产权的行为。用户应自行判断图纸的版权状况，合理使用相关资源。
        </p>
        <h2>免责声明</h2>
        <p>
          拼豆图纸小鼻嘎按"现状"提供服务，不保证服务的连续性、及时性、安全性或无错误。对于因网络环境、设备兼容性、第三方服务异常、内容来源变更、用户误操作或其他不可抗力因素导致的直接或间接损失，拼豆图纸小鼻嘎不承担赔偿责任。拼豆图纸小鼻嘎不对站内图纸的准确性、完整性或适用性做任何明示或暗示的保证。
        </p>
        <h2>服务变更与终止</h2>
        <p>
          拼豆图纸小鼻嘎有权根据业务发展需要，随时修改、暂停或终止全部或部分服务。如拼豆图纸小鼻嘎决定终止服务，将尽可能提前通知用户。对于因服务终止导致的用户损失，拼豆图纸小鼻嘎不承担赔偿责任，法律另有规定的除外。
        </p>
        <h2>条款的更新与修改</h2>
        <p>当拼豆图纸小鼻嘎的功能、内容或运营策略发生变化时，我们可能更新本使用条款。更新后的条款会直接发布在本页面，拼豆图纸小鼻嘎建议用户定期查阅最新条款。用户在条款更新后继续使用拼豆图纸小鼻嘎服务，即视为已接受更新后的条款。如用户不同意更新后的条款，应立即停止使用拼豆图纸小鼻嘎的服务。
        </p>
        <h2>争议解决</h2>
        <p>
          本条款的解释和执行适用中华人民共和国法律。如因使用拼豆图纸小鼻嘎服务产生争议，双方应友好协商解决；协商不成的，任何一方可向拼豆图纸小鼻嘎所在地有管辖权的人民法院提起诉讼。
        </p>
        <h2>联系我们</h2>
        <p>
          如用户对拼豆图纸小鼻嘎的使用条款有任何疑问或建议，可通过拼豆图纸小鼻嘎页面提供的联系方式与我们联系。拼豆图纸小鼻嘎会认真听取用户意见，不断改进服务质量。
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
