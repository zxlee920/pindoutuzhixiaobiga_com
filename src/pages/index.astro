---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '@/config';
import { getFirstImage } from '@/utils/blog';

const { list } = siteConfig;
const allPosts = await getCollection('posts');
type BlogPost = (typeof allPosts)[number];

const posts = allPosts.sort(
  (a: BlogPost, b: BlogPost) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const postsPerPage = list.postsPerPage;
const currentPage = 1;
const totalPages = Math.max(1, Math.ceil(posts.length / postsPerPage));
const pagedPosts = posts.slice(0, postsPerPage);
const allTags = Array.from(new Set(posts.flatMap((post) => post.data.tags || []))).sort((a, b) =>
  a.localeCompare(b, 'zh-CN')
);
---

<BaseLayout title={siteConfig.seo.title} description={siteConfig.seo.description}>
  <section class="py-8 md:py-12">
    <div class="max-w-6xl mx-auto px-4">
      <div class="mb-8 md:mb-10 text-center">
        <h1 class="text-3xl md:text-4xl font-bold text-purple-800 dark:text-purple-200 mb-3">{list.title}</h1>
        <p class="text-base md:text-lg text-purple-600 dark:text-purple-300">{list.description}</p>
      </div>

      {allTags.length > 0 && (
        <div class="mb-8 md:mb-10">
          <div class="flex flex-wrap items-center justify-center gap-2">
            {allTags.map((tag) => (
              <a
                href={`/tag/${encodeURIComponent(tag)}`}
                class="px-3 py-1.5 text-sm rounded-full bg-purple-200 dark:bg-purple-800 text-purple-700 dark:text-purple-200 hover:bg-purple-300 dark:hover:bg-purple-700 hover:text-purple-900 dark:hover:text-purple-100 transition-colors font-medium"
              >
                #{tag}
              </a>
            ))}
          </div>
        </div>
      )}

      {pagedPosts.length === 0 ? (
        <p class="text-center text-purple-400 py-12">暂无图纸</p>
      ) : (
        <>
          <div class="columns-2 lg:columns-3 gap-4 md:gap-6 [column-fill:balance]">
            {pagedPosts.map((post: BlogPost) => {
              const cover = getFirstImage(post.body) || post.data.image;
              return (
                <a
                  href={`/${post.id}`}
                  class="group mb-4 md:mb-6 break-inside-avoid block bg-white/80 dark:bg-purple-900/80 backdrop-blur border-2 border-purple-200 dark:border-purple-700 rounded-2xl overflow-hidden hover:shadow-xl hover:border-purple-400 dark:hover:border-purple-500 hover:scale-105 transition-all"
                >
                  {cover && (
                    <img
                      src={cover}
                      alt={post.data.title}
                      class="w-full object-cover"
                      loading="lazy"
                    />
                  )}
                  <div class="p-4">
                    <h2 class="text-base font-semibold text-purple-900 dark:text-purple-100 group-hover:text-purple-600 dark:group-hover:text-purple-300 transition-colors line-clamp-2">
                      {post.data.title}
                    </h2>
                    <p class="mt-2 text-sm text-purple-600 dark:text-purple-400 line-clamp-3">{post.data.description}</p>
                  </div>
                </a>
              );
            })}
          </div>

          {totalPages > 1 && (
            <nav class="pt-4 flex items-center justify-center gap-2" aria-label="首页分页">
              <span class="px-3 py-1.5 text-sm rounded-lg border-2 border-purple-200 dark:border-purple-700 text-purple-400 dark:text-purple-500">
                上一页
              </span>
              {Array.from({ length: totalPages }, (_, i) => i + 1).map((page) => (
                <a
                  href={page === 1 ? '/' : `/page/${page}`}
                  class:list={[
                    'px-3 py-1.5 text-sm rounded-lg border-2 transition-colors font-medium',
                    page === currentPage
                      ? 'border-purple-500 bg-purple-500 text-white'
                      : 'border-purple-200 dark:border-purple-700 text-purple-600 dark:text-purple-300 hover:border-purple-400 dark:hover:border-purple-500 hover:bg-purple-100 dark:hover:bg-purple-800',
                  ]}
                  aria-current={page === currentPage ? 'page' : undefined}
                >
                  {page}
                </a>
              ))}
              <a
                href={`/page/${currentPage + 1}`}
                class="px-3 py-1.5 text-sm rounded-lg border-2 border-purple-200 dark:border-purple-700 text-purple-600 dark:text-purple-300 hover:border-purple-400 dark:hover:border-purple-500 hover:bg-purple-100 dark:hover:bg-purple-800 transition-colors font-medium"
              >
                下一页
              </a>
            </nav>
          )}
        </>
      )}
    </div>
  </section>
</BaseLayout>
