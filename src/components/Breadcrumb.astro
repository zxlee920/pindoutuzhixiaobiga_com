---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="面包屑" class="max-w-6xl mx-auto px-4 py-3">
  <ol class="flex items-center gap-1.5 text-sm text-purple-400 dark:text-purple-500 flex-wrap">
    {items.map((item, i) => (
      <li class="flex items-center gap-1.5">
        {i > 0 && (
          <svg class="w-3.5 h-3.5 text-purple-300 dark:text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        )}
        {item.href ? (
          <a href={item.href} class="hover:text-purple-600 dark:hover:text-purple-300 transition-colors font-medium">
            {item.label}
          </a>
        ) : (
          <span class="text-purple-700 dark:text-purple-200 font-medium">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
